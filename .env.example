# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001
NEXT_PUBLIC_GRAPH_POLL_SECONDS=8

# Backend
MONGO_URI=mongodb://mongodb:27017
MONGO_DB=shadowgraph
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shadowgraph_password
REDIS_URL=redis://redis:6379/0
JWT_SECRET=replace_me_super_secret
JWT_ALGORITHM=HS256
AI_SERVICE_URL=http://ai-services:8100
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
LOG_LEVEL=INFO
APP_ENV=development
APP_RELEASE=shadowgraph-local

# Security hardening
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=240
JWT_AUDIENCE=shadowgraph-users
JWT_ISSUER=shadowgraph-backend
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60

# Error tracking (optional)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Neo4j
NEO4J_AUTH=neo4j/shadowgraph_password
